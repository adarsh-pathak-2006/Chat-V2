# Django Setup
SECRET_KEY="your-super-secret-key-for-production"
DEBUG=False
ALLOWED_HOSTS="yourdomain.com,api.yourdomain.com,localhost,127.0.0.1"

# CORS Setup
# Set to True for local development, False for production
CORS_ALLOW_ALL_ORIGINS=True
# If CORS_ALLOW_ALL_ORIGINS is False, whitelist your frontend domains
CORS_ALLOWED_ORIGINS="https://yourfrontend.com,http://localhost:3000"

# Database Setup (Optional)
# If omitted, it defaults to db.sqlite3
# DATABASE_URL="postgres://user:password@hostname:port/dbname"

# Redis Setup (Required for Channels)
# Defaults to localhost:6379 if omitted
# REDIS_URL="redis://localhost:6379"
